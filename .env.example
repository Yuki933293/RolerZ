# ============================================
# RolerZ 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ============================================

# ── JWT 密钥（必填）──
# 用于签发登录 token，建议随机生成一个长字符串
# python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-jwt-secret-here

# ── LLM API Keys（按需填写）──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ── 数据加密（可选）──
# 留空则自动生成 data/.encryption_key 文件
# 生产环境建议设置环境变量而非文件
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── 邮件服务（邮箱验证/密码重置必填）──
# 支持 QQ 邮箱、163 邮箱、Gmail 等 SMTP 服务
#
# QQ 邮箱配置示例：
#   1. 登录 mail.qq.com → 设置 → 账户 → POP3/SMTP 服务 → 开启
#   2. 按提示用手机发短信获取「授权码」（不是 QQ 密码）
#   3. 填入下方配置
#
# 163 邮箱配置示例：
#   1. 登录 mail.163.com → 设置 → POP3/SMTP → 开启
#   2. 设置「客户端授权密码」
#   3. SMTP_HOST=smtp.163.com

EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASSWORD=your-authorization-code

# 或使用 Resend API（国际化方案）
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxx

# ── OAuth（Phase 2，社交登录）──
# Google OAuth: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# GitHub OAuth: https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/github/callback

# Cloudflare Turnstile: https://dash.cloudflare.com/turnstile
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
